# Скопируйте этот файл в .env и впишите свои значения.
# Файл .env в репозиторий не попадает (см. .gitignore).

# Какую модель использовать: gigachat или anthropic
LLM_PROVIDER=gigachat

# --- GigaChat (Сбер) ---
# "Ключ авторизации" (Authorization key, длинная строка base64) из личного кабинета.
GIGACHAT_CREDENTIALS=
# Для физлиц - GIGACHAT_API_PERS, для компаний - GIGACHAT_API_B2B
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# Модель: GigaChat | GigaChat-Pro | GigaChat-Max
GIGACHAT_MODEL=GigaChat

# --- Anthropic (запасной вариант) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Telegram (подключим на следующем шаге) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

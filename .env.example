# Скопируйте этот файл в .env и впишите свои значения.
# Файл .env в репозиторий не попадает (см. .gitignore).

# Какую модель использовать: yandex, gigachat или anthropic
LLM_PROVIDER=yandex

# --- YandexGPT (Yandex Cloud) ---
# API-ключ сервисного аккаунта и идентификатор каталога (folder).
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
# Модель: yandexgpt | yandexgpt-lite
YANDEX_MODEL=yandexgpt

# --- GigaChat (Сбер) - запасной ---
# "Ключ авторизации" (Authorization key, длинная строка base64) из личного кабинета.
GIGACHAT_CREDENTIALS=
# Для физлиц - GIGACHAT_API_PERS, для компаний - GIGACHAT_API_B2B
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# Модель: GigaChat | GigaChat-Pro | GigaChat-Max
GIGACHAT_MODEL=GigaChat

# --- Anthropic (запасной вариант для дайджеста + «Разбор дня» с веб-поиском) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# Модель Anthropic для «Разбора дня», если идём через Anthropic.
FEATURE_MODEL=claude-sonnet-4-6

# --- OpenAI (движок «Разбора дня» с веб-поиском) ---
OPENAI_API_KEY=
# openai | anthropic | yandex - каким движком делать «Разбор дня» (agent5_feature)
FEATURE_PROVIDER=openai
# Модель со встроенным веб-поиском: gpt-4o-search-preview (качество) | gpt-4o-mini-search-preview (дешевле)
OPENAI_MODEL=gpt-4o-search-preview

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
# Канал для публикаций: @имя_канала (публичный) или -100... (закрытый)
TELEGRAM_CHAT_ID=
# Ваш личный чат с ботом - туда в пятницу приходит выбор персоны недели.
# Узнать свой id: напишите боту любое сообщение и запустите
#   py agents/notify_telegram.py --updates
TELEGRAM_OWNER_CHAT_ID=

# --- Max (max.ru) ---
# Токен бота от @MasterBot. Если не задан - публикация в Max молча пропускается.
MAX_BOT_TOKEN=
# Числовой id канала. Добавьте бота админом в канал и узнайте id:
#   py agents/notify_max.py --chats
MAX_CHAT_ID=
# user_id получателей личных сообщений в Max (через запятую) - сейчас для комиксов.
# Узнать: человек пишет боту в личку, затем  py agents/notify_max.py --updates
MAX_DM_RECIPIENTS=
